generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model admins {
  id              Int       @id @default(autoincrement())
  name            String?   @db.VarChar(255)
  email           String    @unique @db.VarChar(255)
  password        String    @db.VarChar(255)
  mobile          String?   @db.VarChar(20)
  role            String?   @default("Admin") @db.VarChar(50)
  store_name      String?   @db.VarChar(255)
  store_address   String?
  city            String?   @db.VarChar(100)
  state           String?   @db.VarChar(100)
  pincode         String?   @db.VarChar(20)
  otp             String?   @db.VarChar(6)
  otp_expiry      DateTime? @db.Timestamp(6)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  updated_at      DateTime? @default(now()) @db.Timestamp(6)
  drug_license_no String?   @db.VarChar(255)
  gst_no          String?   @db.VarChar(20)
  profile_image   String?
  temp_new_email  String?   @db.VarChar(255)
}

model banners {
  id           Int         @id @default(autoincrement())
  banner_image String?
  category_id  Int?
  status       Int?        @default(1)
  created_at   DateTime?   @default(now()) @db.Timestamp(6)
  updated_at   DateTime?   @default(now()) @db.Timestamp(6)
  categories   categories? @relation(fields: [category_id], references: [id], onUpdate: NoAction)
}

model brands {
  id          Int         @id @default(autoincrement())
  brand_name  String?     @db.VarChar(255)
  brand_image String?
  is_popular  Boolean?    @default(false)
  status      Int?        @default(1)
  created_at  DateTime?   @default(now()) @db.Timestamp(6)
  updated_at  DateTime?   @default(now()) @db.Timestamp(6)
  medicines   medicines[]
}

model categories {
  id             Int         @id @default(autoincrement())
  category_name  String?     @db.VarChar(255)
  category_image String?
  status         Int?        @default(1)
  created_at     DateTime?   @default(now()) @db.Timestamp(6)
  updated_at     DateTime?   @default(now()) @db.Timestamp(6)
  banners        banners[]
  medicines      medicines[]
}

model coupons {
  id                 Int       @id @default(autoincrement())
  coupon_code        String?   @db.VarChar(50)
  coupon_title       String?   @db.VarChar(255)
  coupon_description String?
  expiry_date        DateTime? @db.Date
  min_order_amount   Decimal?  @default(0) @db.Decimal(10, 2)
  discount           Decimal?  @default(0) @db.Decimal(10, 2)
  status             Int?      @default(1)
  created_at         DateTime? @default(now()) @db.Timestamp(6)
  updated_at         DateTime? @default(now()) @db.Timestamp(6)
  coupon_image       String?   @db.VarChar(255)
}

model customers {
  id              Int               @id @default(autoincrement())
  name            String?           @db.VarChar(255)
  email           String?           @db.VarChar(255)
  mobile          String?           @db.VarChar(20)
  total_orders    Int?              @default(0)
  status          Int?              @default(1)
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  updated_at      DateTime?         @default(now()) @db.Timestamp(6)
  address         String?
  medicine_orders medicine_orders[]
}

model delivery_boys {
  id                    Int               @id @default(autoincrement())
  name                  String?           @db.VarChar(255)
  mobile                String?           @db.VarChar(20)
  email                 String?           @db.VarChar(255)
  commission_percentage Decimal?          @default(0) @db.Decimal(5, 2)
  address               String?
  status                Int?              @default(1)
  created_at            DateTime?         @default(now()) @db.Timestamp(6)
  updated_at            DateTime?         @default(now()) @db.Timestamp(6)
  medicine_orders       medicine_orders[]
}

model devices {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(255)
  device_image  String?   @db.VarChar(255)
  amount        Decimal?  @default(0) @db.Decimal(10, 2)
  is_rghs       Boolean?  @default(false)
  discount      Decimal?  @default(0) @db.Decimal(5, 2)
  rghs_discount Decimal?  @default(0) @db.Decimal(5, 2)
  status        Int?      @default(1)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
}

model general_items {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  image      String?   @db.VarChar(255)
  amount     Decimal?  @default(0) @db.Decimal(10, 2)
  discount   Decimal?  @default(0) @db.Decimal(5, 2)
  status     Int?      @default(1)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
}

model lab_test_categories {
  id            Int         @id @default(autoincrement())
  category_name String      @db.VarChar(255)
  image         String?
  status        Int?        @default(1)
  created_at    DateTime?   @default(now()) @db.Timestamp(6)
  lab_tests     lab_tests[]
}

model lab_test_items {
  id         Int        @id @default(autoincrement())
  combo_id   Int?
  test_id    Int?
  created_at DateTime?  @default(now()) @db.Timestamp(6)
  combo      lab_tests? @relation("combo_to_items", fields: [combo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  test       lab_tests? @relation("test_to_items", fields: [test_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model lab_tests {
  id                          Int                  @id @default(autoincrement())
  test_name                   String?              @db.VarChar(255)
  amount                      Decimal?             @default(0) @db.Decimal(10, 2)
  discount                    Decimal?             @default(0) @db.Decimal(10, 2)
  rghs_discount               Decimal?             @default(0) @db.Decimal(10, 2)
  is_rghs                     Boolean?             @default(false)
  description                 String?
  status                      Int?                 @default(1)
  created_at                  DateTime?            @default(now()) @db.Timestamp(6)
  updated_at                  DateTime?            @default(now()) @db.Timestamp(6)
  image                       String?              @db.VarChar(255)
  lab_test_type               String?              @default("Singular") @db.VarChar(100)
  package_name                String?              @db.VarChar(255)
  category_id                 Int?
  is_popular                  Boolean?             @default(false)
  lab_partner_name            String?              @db.VarChar(255)
  lab_partner_id_old          Int?                 // Kept for manual check but we'll use lab_partners model
  lab_rating                  Decimal?             @default(0) @db.Decimal(3, 2)
  lab_accreditation           String?              @db.VarChar(255)
  free_home_collection        Boolean?             @default(false)
  report_turnaround_time      String?              @db.VarChar(100)
  test_prerequisites          String[]
  parameters_count            String?              @db.VarChar(100)
  included_parameters_details Json?
  included_test_items         lab_test_items[]     @relation("combo_to_items")
  appears_in_combos           lab_test_items[]     @relation("test_to_items")
  lab_test_categories         lab_test_categories? @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  lab_test_appointments       lab_test_appointments[]
  lab_test_schedules          lab_test_schedules[]
  lab_partner_id              Int?
  lab_partners                lab_partners?        @relation(fields: [lab_partner_id], references: [id], onUpdate: NoAction)
}

model lab_partners {
  id                Int         @id @default(autoincrement())
  name              String      @db.VarChar(255)
  logo              String?
  rating            Decimal?    @default(0) @db.Decimal(3, 2)
  accreditation     String?     @db.VarChar(255)
  description       String?
  status            Int?        @default(1)
  created_at        DateTime?   @default(now()) @db.Timestamp(6)
  updated_at        DateTime?   @default(now()) @db.Timestamp(6)
  lab_tests         lab_tests[]
}

model lab_test_appointments {
  id                   Int       @id @default(autoincrement())
  lab_test_id          Int?
  user_id              Int?
  patient_name         String?   @db.VarChar(255)
  mobile               String?   @db.VarChar(20)
  appointment_date     DateTime  @db.Date
  appointment_time     DateTime  @db.Time(6)
  home_collection      Boolean   @default(false)
  address              String?
  status               String?   @default("pending") @db.VarChar(50)
  total_amount         Decimal?  @default(0) @db.Decimal(10, 2)
  created_at           DateTime? @default(now()) @db.Timestamp(6)
  updated_at           DateTime? @default(now()) @db.Timestamp(6)
  lab_tests            lab_tests? @relation(fields: [lab_test_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model lab_test_schedules {
  id               Int       @id @default(autoincrement())
  lab_test_id      Int
  day_of_week      String?   @db.VarChar(20)
  start_time       String?   @db.VarChar(20)
  end_time         String?   @db.VarChar(20)
  status           Int?      @default(1)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)
  lab_tests        lab_tests? @relation(fields: [lab_test_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model medicine_order_items {
  id              Int              @id @default(autoincrement())
  order_id        Int?
  medicine_id     Int?
  quantity        Int?             @default(1)
  price           Decimal?         @default(0) @db.Decimal(10, 2)
  discount        Decimal?         @default(0) @db.Decimal(10, 2)
  item_total      Decimal?         @default(0) @db.Decimal(10, 2)
  medicines       medicines?       @relation(fields: [medicine_id], references: [id], onUpdate: NoAction)
  medicine_orders medicine_orders? @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model medicine_orders {
  id                   Int                    @id @default(autoincrement())
  customer_id          Int?
  delivery_boy_id      Int?
  total_price          Decimal?               @default(0) @db.Decimal(10, 2)
  sub_total_price      Decimal?               @default(0) @db.Decimal(10, 2)
  delivery_charge      Decimal?               @default(0) @db.Decimal(10, 2)
  payment_method       String?                @db.VarChar(50)
  transaction_id       String?                @db.VarChar(255)
  address              String?
  current_status       String?                @default("Pending") @db.VarChar(50)
  order_flow           String?                @default("Waiting For Decision") @db.VarChar(100)
  created_at           DateTime?              @default(now()) @db.Timestamp(6)
  updated_at           DateTime?              @default(now()) @db.Timestamp(6)
  order_type           String?                @default("Normal") @db.VarChar(20)
  prescription_images  String[]
  customer_id_manual   Int?
  RGHS_Tid             String?                @db.VarChar(255)
  user_action          String?                @default("pending") @db.VarChar(20)
  doctor_name          String?                @db.VarChar(255)
  prescription_date    DateTime?              @db.Date
  medicine_order_items medicine_order_items[]
  customers            customers?             @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  delivery_boys        delivery_boys?         @relation(fields: [delivery_boy_id], references: [id], onUpdate: NoAction)
  system_cart          system_cart[]
}

model medicines {
  id                    Int                    @id @default(autoincrement())
  medicine_name         String?                @db.VarChar(255)
  medicine_image        String?
  category_id           Int?
  brand_id              Int?
  medicine_description  String?
  price                 Decimal?               @default(0) @db.Decimal(10, 2)
  stock_status          String?                @default("In Stock") @db.VarChar(50)
  stock_quantity        Int?                   @default(0)
  prescription_required Boolean?               @default(false)
  status                Int?                   @default(1)
  created_at            DateTime?              @default(now()) @db.Timestamp(6)
  updated_at            DateTime?              @default(now()) @db.Timestamp(6)
  medicine_type         String?                @db.VarChar(100)
  medicine_discount     Decimal?               @default(0) @db.Decimal(10, 2)
  rghs_discount         Decimal?               @default(0) @db.Decimal(10, 2)
  medicine_images       String[]
  pack_type             String?                @db.VarChar(50)
  medicine_rghs         Boolean?               @default(false)
  salt_composition      String?                @db.VarChar(255)
  manufacturer          String?                @db.VarChar(255)
  packaging             String?                @db.VarChar(255)
  what_it_is_used_for   String?
  how_it_works          String?
  safety_advice         Json?
  expert_advice         String[]
  medicine_order_items  medicine_order_items[]
  brands                brands?                @relation(fields: [brand_id], references: [id], onUpdate: NoAction)
  categories            categories?            @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  system_cart           system_cart[]
}

model order_items {
  id           Int       @id @default(autoincrement())
  order_id     Int?
  item_name    String?   @db.VarChar(255)
  item_details String?
  quantity     Int?      @default(1)
  price        Decimal?  @default(0) @db.Decimal(10, 2)
  mrp          Decimal?  @default(0) @db.Decimal(10, 2)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  orders       orders?   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model orders {
  id               Int           @id @default(autoincrement())
  user_id          Int?
  order_name       String?       @db.VarChar(255)
  order_image      String?
  delivery_date    DateTime?     @db.Date
  order_type       String?       @db.VarChar(50)
  beneficiary_name String?       @db.VarChar(255)
  delivery_address String?
  total_items      Int?          @default(0)
  total_amount     Decimal?      @default(0) @db.Decimal(10, 2)
  total_mrp        Decimal?      @default(0) @db.Decimal(10, 2)
  status           String?       @default("pending") @db.VarChar(50)
  created_at       DateTime?     @default(now()) @db.Timestamp(6)
  updated_at       DateTime?     @default(now()) @db.Timestamp(6)
  order_items      order_items[]
  order_tracking   order_tracking[]
  users            users?        @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model order_tracking {
  id               Int       @id @default(autoincrement())
  order_id         Int
  status           String    @db.VarChar(50)
  message          String?   @db.VarChar(255) // e.g., "Your order has been shipped"
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  orders           orders?   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model payment_gateways {
  id            Int       @id @default(autoincrement())
  gateway_name  String?   @db.VarChar(255)
  gateway_image String?
  status        Int?      @default(1)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  updated_at    DateTime? @default(now()) @db.Timestamp(6)
}

model system_cart {
  id              Int              @id @default(autoincrement())
  order_id        Int?
  medicine_id     Int?
  num_strips      Int?             @default(1)
  pack_type       String?          @db.VarChar(50)
  quantity        Int?             @default(1)
  price           Decimal?         @default(0) @db.Decimal(10, 2)
  discount        Decimal?         @default(0) @db.Decimal(10, 2)
  item_total      Decimal?         @default(0) @db.Decimal(10, 2)
  created_at      DateTime?        @default(now()) @db.Timestamp(6)
  medicines       medicines?       @relation(fields: [medicine_id], references: [id], onUpdate: NoAction)
  medicine_orders medicine_orders? @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model system_settings {
  id                Int       @id @default(autoincrement())
  dashboard_name    String?   @default("SOMACY") @db.VarChar(255)
  short_name        String?   @default("NK") @db.VarChar(50)
  currency          String?   @default("₹") @db.VarChar(10)
  timezone          String?   @default("Asia/Kolkata") @db.VarChar(100)
  show_prescription String?   @default("Yes") @db.VarChar(10)
  logo              String?   @db.VarChar(255)
  user_app_id       String?   @db.VarChar(255)
  user_app_key      String?   @db.VarChar(255)
  delivery_app_id   String?   @db.VarChar(255)
  delivery_app_key  String?   @db.VarChar(255)
  store_name        String?   @db.VarChar(255)
  store_mobile      String?   @db.VarChar(20)
  store_email       String?   @db.VarChar(255)
  contact_us        String?   @db.VarChar(20)
  store_address     String?
  about_us          String?
  latitude          String?   @db.VarChar(50)
  longitude         String?   @db.VarChar(50)
  delivery_radius   String?   @db.VarChar(50)
  per_km_price      String?   @db.VarChar(50)
  referral_amount   String?   @db.VarChar(50)
  sign_up_amount    String?   @db.VarChar(50)
  privacy_policy    String?
  terms_conditions  String?
  created_at        DateTime? @default(now()) @db.Timestamp(6)
  updated_at        DateTime? @default(now()) @db.Timestamp(6)
}

model testimonials {
  id          Int       @id @default(autoincrement())
  name        String?   @db.VarChar(255)
  designation String?   @db.VarChar(255)
  content     String?
  image       String?
  status      Int?      @default(1)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
}

model user_cart {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  item_id    Int
  item_type  String    @db.VarChar(50)
  item_name  String?   @db.VarChar(255)
  price      Decimal?  @default(0) @db.Decimal(10, 2)
  quantity   Int?      @default(1)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id         Int         @id @default(autoincrement())
  first_name String?     @db.VarChar(255)
  last_name  String?     @db.VarChar(255)
  mobile     String      @unique @db.VarChar(20)
  password   String?     @db.VarChar(255)
  otp        String?     @db.VarChar(6)
  address    String?
  created_at DateTime?   @default(now()) @db.Timestamp(6)
  updated_at DateTime?   @default(now()) @db.Timestamp(6)
  orders         orders[]
  user_cart      user_cart[]
  user_addresses user_addresses[]
}

model user_addresses {
  id             Int       @id @default(autoincrement())
  user_id        Int
  address_line1  String?   @db.VarChar(255)
  address_line2  String?   @db.VarChar(255)
  city           String?   @db.VarChar(100)
  state          String?   @db.VarChar(100)
  pincode        String?   @db.VarChar(20)
  address_type   String?   @default("Home") @db.VarChar(50)
  is_default     Boolean?  @default(false)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)
  users          users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model faqs {
  id         Int       @id @default(autoincrement())
  question   String    @db.VarChar(255)
  answer     String?
  status     Int?      @default(1)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
}

model blogs {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  description String?
  content     String?
  image       String?   @db.VarChar(255)
  category    String?   @db.VarChar(100)
  status      Int?      @default(1)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
}

model doctors {
  id                   Int              @id @default(autoincrement())
  name                 String           @db.VarChar(255)
  image                String?          @db.VarChar(255)
  specialization       String?          @db.VarChar(255)
  experience_years      Int?             @default(0)
  consultation_fee     Decimal?         @default(0) @db.Decimal(10, 2)
  location             String?          @db.VarChar(255)
  rating               Decimal?         @default(0) @db.Decimal(3, 2)
  reviews_count        Int?             @default(0)
  about                String?
  education            String[]
  awards               String[]
  specializations_tags String[]
  is_rghs_empanelled   Boolean?         @default(false)
  consultation_modes   Json?            @default("\"[\\\"Video\\\", \\\"Voice\\\", \\\"Chat\\\", \\\"In-Clinic\\\"]\"")
  status               Int?             @default(1)
  created_at           DateTime?        @default(now()) @db.Timestamp(6)
  updated_at           DateTime?        @default(now()) @db.Timestamp(6)
  appointments         appointments[]
  doctor_reviews       doctor_reviews[]
  doctor_schedules     doctor_schedules[]
}

model doctor_schedules {
  id               Int       @id @default(autoincrement())
  doctor_id        Int
  day_of_week      String?   @db.VarChar(20)
  start_time       String?   @db.VarChar(20)
  end_time         String?   @db.VarChar(20)
  status           Int?      @default(1)
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @db.Timestamp(6)
  doctors          doctors?  @relation(fields: [doctor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model doctor_reviews {
  id           Int       @id @default(autoincrement())
  doctor_id    Int?
  patient_name String?   @db.VarChar(255)
  rating       Int?      @default(5)
  comment      String?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  doctors      doctors?  @relation(fields: [doctor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model appointments {
  id                   Int       @id @default(autoincrement())
  doctor_id            Int?
  user_id              Int?
  patient_name         String?   @db.VarChar(255)
  patient_id           String?   @db.VarChar(100)
  consultation_mode    String?   @db.VarChar(50)
  appointment_date     DateTime  @db.Date
  appointment_time     DateTime  @db.Time(6)
  fee                  Decimal?  @default(0) @db.Decimal(10, 2)
  total_payable        Decimal?  @default(0) @db.Decimal(10, 2)
  status               String?   @default("scheduled") @db.VarChar(50)
  rghs_benefit_applied Boolean?  @default(false)
  created_at           DateTime? @default(now()) @db.Timestamp(6)
  updated_at           DateTime? @default(now()) @db.Timestamp(6)
  doctors              doctors?  @relation(fields: [doctor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model contact_submissions {
  id             Int       @id @default(autoincrement())
  full_name      String    @db.VarChar(255)
  contact_number String    @db.VarChar(20)
  email_address  String    @db.VarChar(255)
  message        String
  created_at     DateTime? @default(now()) @db.Timestamp(6)
}

model video_tutorials {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  subtitle    String?   @db.VarChar(255)
  thumbnail   String?
  video_link  String
  duration    String?   @db.VarChar(50)
  status      Int?      @default(1)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
}
